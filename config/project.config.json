{
  "_comment": "ArchonFlow Project Configuration — Edit this file to match your project",

  "project": {
    "name": "",
    "description": "",
    "version": "0.5.0",

    "techStack": {
      "framework": "",
      "language": "typescript",
      "styling": "",
      "stateManagement": "",
      "buildTool": ""
    },

    "backendTech": {
      "framework": "",
      "language": "",
      "orm": "",
      "database": "",
      "sourceDir": ""
    }
  },

  "designSource": {
    "mode": "",
    "tool": "",
    "exportFormat": "html+css",
    "designDoc": "DESIGN.md",

    "supportedTools": ["stitch", "figma", "sketch", "xd"],

    "autoDiscovery": {
      "enabled": true,
      "searchPatterns": {
        "stitch": {
          "html": ["**/stitch*/**/*.html", "**/stitch-*/**/*.html"],
          "screenshots": ["**/screenshots/**/*.png", "**/screenshots/**/*.jpg"],
          "keywords": ["stitch"]
        },
        "figma": {
          "html": ["**/figma*/**/*.html", "**/figma-export/**/*.html"],
          "screenshots": ["**/figma*/**/*.png"],
          "keywords": ["figma"]
        },
        "generic": {
          "html": ["**/design*/**/*.html", "**/design-references/**/*.html"],
          "screenshots": ["**/design*/**/*.png", "**/design*/**/*.jpg"],
          "keywords": ["design"]
        }
      },
      "fallbackDir": "design-references/"
    },

    "toolConfig": {
      "stitch": {
        "exportStructure": "flat",
        "assetHandling": "inline",
        "namingPatterns": {
          "html": ["{page}.html", "unknown-{id}.html"],
          "screenshot": ["{page}.png", "{page}.jpg"]
        }
      },
      "figma": {
        "exportStructure": "per-frame",
        "assetHandling": "export",
        "apiToken": ""
      }
    }
  },

  "pipeline": {
    "mode": "",
    "visualAudit": true,
    "uxAudit": true,
    "apiCompliance": true,
    "backendAudit": true,
    "codeReview": true,
    "maxFixIterations": 3,

    "gates": [
      { "agent": "visualAuditor", "minScore": 95, "blocks": "codeBackendReviewer" },
      { "agent": "apiIntegrationAuditor", "minScore": 95, "blocks": "codeBackendReviewer" },
      { "agent": "uxCompliance", "minScore": 90, "blocks": "codeBackendReviewer" },
      { "agent": "codeBackendReviewer", "minScore": 85, "blocks": "deployment" }
    ],

    "twoStageReview": true,
    "stage1": ["visualAuditor", "apiIntegrationAuditor", "uxCompliance"],
    "stage2": ["codeBackendReviewer"]
  },

  "directories": {
    "source": "src/",
    "pages": "src/pages/",
    "components": "src/components/",
    "composables": "src/composables/",
    "styles": "src/styles/",
    "tokens": "src/styles/tokens/",
    "changes": "archonflow/changes/",
    "specs": "archonflow/specs/",
    "contracts": "archonflow/contracts/",
    "auditReports": "archonflow/audits/",
    "visualReports": "archonflow/visual-reports/",
    "uxReports": "archonflow/ux-reports/",
    "reviewReports": "archonflow/reports/",
    "mockData": "archonflow/mock/",
    "memory": "archonflow/memory/",
    "templates": "archonflow/templates/",
    "designReferences": "design-references/",
    "changelog": "archonflow/changelog.md"
  },

  "scoring": {
    "thresholds": {
      "visual": 95,
      "apiIntegration": 95,
      "uxCompliance": 90,
      "codeBackend": 85
    },

    "dimensions": {
      "color": { "weight": 0.25, "enabled": true },
      "typography": { "weight": 0.20, "enabled": true },
      "spacing": { "weight": 0.20, "enabled": true },
      "radius": { "weight": 0.15, "enabled": true },
      "layout": { "weight": 0.15, "enabled": true },
      "shadow": { "weight": 0.05, "enabled": true }
    },

    "apiIntegrationDimensions": {
      "schemaCompliance": { "weight": 0.35 },
      "statusCodeAccuracy": { "weight": 0.20 },
      "errorFormat": { "weight": 0.15 },
      "authentication": { "weight": 0.15 },
      "backwardCompatibility": { "weight": 0.15 },
      "dataFlow": { "weight": 0.30 },
      "errorPropagation": { "weight": 0.25 },
      "stateConsistency": { "weight": 0.25 },
      "edgeCaseCoverage": { "weight": 0.20 }
    },

    "codeBackendDimensions": {
      "security": { "weight": 0.30 },
      "performance": { "weight": 0.25 },
      "dataIntegrity": { "weight": 0.25 },
      "errorHandling": { "weight": 0.20 },
      "readability": { "weight": 0.25 },
      "patternConsistency": { "weight": 0.25 },
      "testCoverage": { "weight": 0.25 },
      "assumptionCompliance": { "weight": 0.25 }
    },

    "colorComparison": {
      "method": "ciede2000",
      "thresholds": {
        "imperceptible": 2,
        "slight": 5,
        "visible": 10
      }
    },

    "spacingTolerance": {
      "exact": 0,
      "acceptable": 2,
      "warning": 4,
      "critical": 8
    }
  },

  "viewports": {
    "mobile": { "width": 375, "height": 812, "deviceScaleFactor": 3 },
    "tablet": { "width": 768, "height": 1024, "deviceScaleFactor": 2 },
    "desktop": { "width": 1440, "height": 900, "deviceScaleFactor": 2 }
  },

  "audit": {
    "phases": ["static", "visual"],
    "phaseWeights": {
      "static": 0.6,
      "visual": 0.4
    },
    "screenshotFormat": "png",
    "diffMethod": "pixel",
    "ignoreDynamicContent": true,
    "defaultIgnoreSelectors": [
      "[data-dynamic]",
      ".loading-skeleton",
      ".timestamp"
    ],
    "visualAuditSeparation": {
      "enabled": true,
      "calculationScript": "scripts/visual-diff.ts",
      "interpretationOnly": true
    },
    "contractAssertion": {
      "enabled": true,
      "compilerScript": "scripts/contract-compiler.ts",
      "assertionScript": "scripts/contract-assert.ts",
      "assertionsFile": "assertions.json",
      "gateKeeping": true
    },
    "vrt": {
      "enabled": true,
      "baselineScript": "scripts/vrt-baseline.ts",
      "assertionScript": "scripts/vrt-assert.ts",
      "baselinesDir": "test/vrt/baselines",
      "resultsDir": "test/vrt/results",
      "maxDiffPixelRatio": 0.01,
      "maskSelectors": [
        "[data-vrt-mask]",
        ".timestamp",
        ".avatar",
        ".ad-banner",
        "video",
        "canvas",
        "iframe"
      ],
      "maskColor": "#808080",
      "driftProtection": true,
      "changelogFile": "test/vrt/changelog.vrt.md"
    },
    "visualImpactAnalysis": {
      "enabled": true,
      "script": "scripts/visual-impact.ts",
      "autoTriggerVrt": true
    },
    "feasibilityCheck": {
      "enabled": true,
      "script": "scripts/feasibility-check.ts",
      "blockOnFail": true
    }
  },

  "agents": {
    "systemArchitect": {
      "enabled": true,
      "additionalRules": [],
      "arbiterEnabled": true
    },
    "designAuthority": {
      "enabled": true,
      "additionalRules": [],
      "steps": ["interpretation", "contract", "tokens"]
    },
    "apiArchitect": {
      "enabled": true,
      "additionalRules": [],
      "mockGeneration": true
    },
    "dataArchitect": {
      "enabled": true,
      "additionalRules": []
    },
    "frontendEngineer": {
      "enabled": true,
      "additionalRules": [],
      "forbiddenPatterns": [],
      "tddRequired": true,
      "tddScope": {
        "logic": "mandatory",
        "ui": "recommended"
      }
    },
    "backendEngineer": {
      "enabled": true,
      "additionalRules": [],
      "scope": "business-skeleton",
      "tddRequired": true
    },
    "visualAuditor": {
      "enabled": true,
      "calculationScript": "scripts/visual-diff.ts",
      "interpretationOnly": true,
      "playwrightConfig": {
        "browser": "chromium",
        "headless": true,
        "timeout": 30000
      },
      "additionalRules": []
    },
    "uxCompliance": {
      "enabled": true,
      "accessibilityStandard": "WCAG-AA",
      "minTouchTarget": 44,
      "additionalRules": []
    },
    "apiIntegrationAuditor": {
      "enabled": true,
      "additionalRules": []
    },
    "codeBackendReviewer": {
      "enabled": true,
      "additionalRules": [],
      "maxComponentLines": 200,
      "typeCoverageThreshold": 90
    }
  },

  "projectProfiles": {
    "enterprise": {
      "visualThreshold": 95,
      "apiThreshold": 95,
      "uxThreshold": 90,
      "codeThreshold": 90
    },
    "normal": {
      "visualThreshold": 85,
      "apiThreshold": 90,
      "uxThreshold": 85,
      "codeThreshold": 85
    },
    "internal": {
      "visualThreshold": 70,
      "apiThreshold": 85,
      "uxThreshold": 80,
      "codeThreshold": 80
    }
  },

  "agent_routing": {
    "description": "Model routing configuration for agents. Vision-capable models are only invoked when visual audit is needed. Text/code models handle all other tasks for cost efficiency.",
    "engineer": {
      "model": "sonnet",
      "temperature": 0.2,
      "description": "High-throughput text/code model for implementation and fixes"
    },
    "visual_auditor": {
      "model": "sonnet",
      "vision": true,
      "temperature": 0.0,
      "description": "Vision-capable model for interpreting Three-Image Context and generating Visual_Fix_Spec"
    },
    "architect": {
      "model": "sonnet",
      "temperature": 0.3,
      "description": "Reasoning model for architecture analysis and Arbiter decisions"
    },
    "auditor": {
      "model": "sonnet",
      "temperature": 0.0,
      "description": "Deterministic model for API/UX/code auditing"
    },
    "fallback": {
      "model": "sonnet",
      "description": "Default model when no specific routing is configured"
    }
  },

  "context_control": {
    "description": "Context window management settings to prevent context inflation across fix iterations",
    "memory_reset": {
      "enabled": true,
      "description": "Clear agent session history between fix iterations. Each iteration starts fresh with only current code + latest violation report.",
      "max_history_iterations": 0
    },
    "viewport_snippet": {
      "enabled": true,
      "description": "Only include FAIL items in violation reports passed to Engineer. PASS items are omitted to save context.",
      "fail_only": true
    },
    "surgical_fix_contract": {
      "enabled": true,
      "description": "Engineer is restricted to fixing ONLY the violations listed in the report. No refactoring, no optimization, no changes to unrelated code."
    },
    "context_compress": {
      "enabled": true,
      "trigger_iteration": 3,
      "description": "On iteration 3+, compress previous fix history into a structured summary before passing to Engineer.",
      "max_summary_tokens": 500
    }
  }
}
