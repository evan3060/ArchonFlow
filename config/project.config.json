{
  "_comment": "ArchonFlow Project Configuration — Edit this file to match your project",

  "project": {
    "name": "",
    "description": "",
    "version": "0.1.0",

    "techStack": {
      "framework": "",
      "language": "typescript",
      "styling": "",
      "stateManagement": "",
      "buildTool": ""
    },

    "backendTech": {
      "framework": "",
      "language": "",
      "orm": "",
      "database": "",
      "sourceDir": ""
    }
  },

  "designSource": {
    "mode": "",
    "tool": "",
    "exportFormat": "html+css",
    "designDoc": "DESIGN.md",

    "supportedTools": ["stitch", "figma", "sketch", "xd"],

    "autoDiscovery": {
      "enabled": true,
      "searchPatterns": {
        "stitch": {
          "html": ["**/stitch*/**/*.html", "**/stitch-*/**/*.html"],
          "screenshots": ["**/screenshots/**/*.png", "**/screenshots/**/*.jpg"],
          "keywords": ["stitch"]
        },
        "figma": {
          "html": ["**/figma*/**/*.html", "**/figma-export/**/*.html"],
          "screenshots": ["**/figma*/**/*.png"],
          "keywords": ["figma"]
        },
        "generic": {
          "html": ["**/design*/**/*.html", "**/design-references/**/*.html"],
          "screenshots": ["**/design*/**/*.png", "**/design*/**/*.jpg"],
          "keywords": ["design"]
        }
      },
      "fallbackDir": "design-references/"
    },

    "toolConfig": {
      "stitch": {
        "exportStructure": "flat",
        "assetHandling": "inline",
        "namingPatterns": {
          "html": ["{page}.html", "unknown-{id}.html"],
          "screenshot": ["{page}.png", "{page}.jpg"]
        }
      },
      "figma": {
        "exportStructure": "per-frame",
        "assetHandling": "export",
        "apiToken": ""
      }
    }
  },

  "pipeline": {
    "mode": "",
    "visualAudit": true,
    "uxAudit": true,
    "apiCompliance": true,
    "backendAudit": true,
    "codeReview": true,
    "maxFixIterations": 3,

    "gates": [
      { "agent": "visualAuditor", "minScore": 95, "blocks": "codeReviewer" },
      { "agent": "apiCompliance", "minScore": 95, "blocks": "codeReviewer" },
      { "agent": "uxCompliance", "minScore": 90, "blocks": "codeReviewer" },
      { "agent": "integrationChecker", "minScore": 90, "blocks": "codeReviewer" },
      { "agent": "backendAuditor", "minScore": 85, "blocks": "deployment" },
      { "agent": "codeReviewer", "minScore": 85, "blocks": "deployment" }
    ],

    "twoStageReview": true,
    "stage1": ["visualAuditor", "apiCompliance", "uxCompliance", "integrationChecker"],
    "stage2": ["backendAuditor", "codeReviewer"]
  },

  "directories": {
    "source": "src/",
    "pages": "src/pages/",
    "components": "src/components/",
    "composables": "src/composables/",
    "styles": "src/styles/",
    "tokens": "src/styles/tokens/",
    "changes": "archonflow/changes/",
    "specs": "archonflow/specs/",
    "contracts": "archonflow/contracts/",
    "auditReports": "archonflow/audits/",
    "visualReports": "archonflow/visual-reports/",
    "uxReports": "archonflow/ux-reports/",
    "reviewReports": "archonflow/reports/",
    "mockData": "archonflow/mock/",
    "memory": "archonflow/memory/",
    "templates": "archonflow/templates/",
    "designReferences": "design-references/",
    "changelog": "archonflow/changelog.md"
  },

  "scoring": {
    "thresholds": {
      "visual": 95,
      "apiCompliance": 95,
      "uxCompliance": 90,
      "integration": 90,
      "backendAudit": 85,
      "codeReview": 85
    },

    "dimensions": {
      "color": { "weight": 0.25, "enabled": true },
      "typography": { "weight": 0.20, "enabled": true },
      "spacing": { "weight": 0.20, "enabled": true },
      "radius": { "weight": 0.15, "enabled": true },
      "layout": { "weight": 0.15, "enabled": true },
      "shadow": { "weight": 0.05, "enabled": true }
    },

    "apiComplianceDimensions": {
      "schemaCompliance": { "weight": 0.35 },
      "statusCodeAccuracy": { "weight": 0.20 },
      "errorFormat": { "weight": 0.15 },
      "authentication": { "weight": 0.15 },
      "backwardCompatibility": { "weight": 0.15 }
    },

    "backendAuditDimensions": {
      "security": { "weight": 0.30 },
      "performance": { "weight": 0.25 },
      "dataIntegrity": { "weight": 0.25 },
      "errorHandling": { "weight": 0.20 }
    },

    "colorComparison": {
      "method": "ciede2000",
      "thresholds": {
        "imperceptible": 2,
        "slight": 5,
        "visible": 10
      }
    },

    "spacingTolerance": {
      "exact": 0,
      "acceptable": 2,
      "warning": 4,
      "critical": 8
    }
  },

  "viewports": {
    "mobile": { "width": 375, "height": 812, "deviceScaleFactor": 3 },
    "tablet": { "width": 768, "height": 1024, "deviceScaleFactor": 2 },
    "desktop": { "width": 1440, "height": 900, "deviceScaleFactor": 2 }
  },

  "audit": {
    "phases": ["static", "visual"],
    "phaseWeights": {
      "static": 0.6,
      "visual": 0.4
    },
    "screenshotFormat": "png",
    "diffMethod": "pixel",
    "ignoreDynamicContent": true,
    "defaultIgnoreSelectors": [
      "[data-dynamic]",
      ".loading-skeleton",
      ".timestamp"
    ]
  },

  "agents": {
    "systemArchitect": {
      "enabled": true,
      "additionalRules": []
    },
    "designAuthority": {
      "enabled": true,
      "additionalRules": []
    },
    "contractGenerator": {
      "enabled": true,
      "additionalRules": []
    },
    "apiArchitect": {
      "enabled": true,
      "additionalRules": []
    },
    "dataArchitect": {
      "enabled": true,
      "additionalRules": []
    },
    "mockServerGenerator": {
      "enabled": true,
      "additionalRules": []
    },
    "designSystemGuardian": {
      "enabled": true,
      "tokenOutputFormats": ["json", "tailwind", "scss", "css"],
      "additionalRules": []
    },
    "frontendEngineer": {
      "enabled": true,
      "additionalRules": [],
      "forbiddenPatterns": [],
      "tddRequired": true
    },
    "backendEngineer": {
      "enabled": true,
      "additionalRules": [],
      "scope": "api-contract-layer-only",
      "tddRequired": true
    },
    "visualAuditor": {
      "enabled": true,
      "playwrightConfig": {
        "browser": "chromium",
        "headless": true,
        "timeout": 30000
      },
      "additionalRules": []
    },
    "uxCompliance": {
      "enabled": true,
      "accessibilityStandard": "WCAG-AA",
      "minTouchTarget": 44,
      "additionalRules": []
    },
    "apiCompliance": {
      "enabled": true,
      "additionalRules": []
    },
    "integrationChecker": {
      "enabled": true,
      "backendUrl": "http://localhost:3000",
      "additionalRules": []
    },
    "backendAuditor": {
      "enabled": true,
      "additionalRules": []
    },
    "codeReviewer": {
      "enabled": true,
      "maxComponentLines": 200,
      "typeCoverageThreshold": 90,
      "additionalRules": []
    }
  }
}
